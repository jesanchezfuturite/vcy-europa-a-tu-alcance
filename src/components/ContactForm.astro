---
---
<section id="formulario-contacto" class="py-24 bg-purple-deep text-white relative overflow-hidden">
  <!-- Decorative elements -->
  <div class="absolute top-0 left-0 w-64 h-64 bg-white/5 rounded-full -translate-x-1/2 -translate-y-1/2 blur-3xl"></div>
  <div class="absolute bottom-0 right-0 w-96 h-96 bg-purple-400/10 rounded-full translate-x-1/3 translate-y-1/3 blur-3xl"></div>

  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-4xl mx-auto bg-white rounded-[2rem] shadow-2xl overflow-hidden flex flex-col md:flex-row text-gray-800">
      
      <!-- Info Column -->
      <div class="w-full md:w-2/5 p-8 md:p-12 bg-gray-50 border-r border-gray-100 flex flex-col justify-center">
        <h2 class="text-3xl font-bold mb-6 text-purple-deep leading-tight">
          CONOCE CADA DETALLE DE TU VIAJE DÍA POR DÍA
        </h2>
        <p class="text-lg text-gray-600 mb-8">
          Completa el formulario para descargar el itinerario completo en PDF y asegurar la preventa de tu lugar.
        </p>
        <div class="space-y-4">
          <div class="flex items-center gap-4 text-sm font-medium text-gray-500">
            <span class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-deep">✓</span>
            Itinerario detallado
          </div>
          <div class="flex items-center gap-4 text-sm font-medium text-gray-500">
            <span class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center text-purple-deep">✓</span>
            Plan de pagos flexible
          </div>
        </div>
      </div>

      <!-- Form Column -->
      <div class="w-full md:w-3/5 p-8 md:p-12">
        <form id="contact-form" class="space-y-6">
          <div>
            <label for="name" class="block text-sm font-bold uppercase tracking-wider text-gray-400 mb-2">Nombre completo</label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required 
              placeholder="Ej. Juan Pérez"
              class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-deep/20 focus:border-purple-deep transition-all"
            />
          </div>

          <div>
            <label for="phone" class="block text-sm font-bold uppercase tracking-wider text-gray-400 mb-2">Teléfono / WhatsApp</label>
            <input 
              type="tel" 
              id="phone" 
              name="phone" 
              required 
              placeholder="Ej. 55 1234 5678"
              class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-deep/20 focus:border-purple-deep transition-all"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-bold uppercase tracking-wider text-gray-400 mb-2">Correo electrónico</label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required 
              placeholder="tu@email.com"
              class="w-full px-5 py-4 bg-gray-50 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-purple-deep/20 focus:border-purple-deep transition-all"
            />
          </div>

          <button 
            type="submit" 
            id="submit-btn"
            class="w-full bg-purple-deep hover:bg-purple-800 text-white font-bold py-5 rounded-xl text-xl shadow-lg transition-all hover:scale-[1.02] active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Descargar itinerario PDF
          </button>
          
          <p id="form-status" class="text-center text-sm font-medium mt-4 hidden"></p>
        </form>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const statusMsg = document.getElementById('form-status');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    submitBtn.disabled = true;
    submitBtn.innerText = 'Enviando...';
    
    const formData = new FormData(form);
    const data = Object.fromEntries(formData);

    try {
      const response = await fetch('/api/contact', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data),
      });

      if (response.ok) {
        if (statusMsg) {
          statusMsg.innerText = '¡Gracias! Redirigiendo a tu itinerario...';
          statusMsg.classList.remove('hidden', 'text-red-500');
          statusMsg.classList.add('text-green-600');
        }
        form.reset();
        
        // Simulate PDF Download / Success
        setTimeout(() => {
          window.open('https://example.com/itinerario-europa-2027.pdf', '_blank');
        }, 1500);
      } else {
        throw new Error('Error al enviar');
      }
    } catch (error) {
      if (statusMsg) {
        statusMsg.innerText = 'Hubo un error. Por favor intenta de nuevo.';
        statusMsg.classList.remove('hidden', 'text-green-600');
        statusMsg.classList.add('text-red-500');
      }
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerText = 'Descargar itinerario PDF';
    }
  });
</script>
