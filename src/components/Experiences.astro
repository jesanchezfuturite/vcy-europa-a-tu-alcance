---
const experiences = [
  {
    title: "Ver encenderse la Torre Eiffel.",
    image: "https://images.unsplash.com/photo-1511739001486-6bfe10ce785f?q=80&w=1974&auto=format&fit=crop",
  },
  {
    title: "Divertirte con la clásica foto en la Torre de Pisa.",
    image: "https://images.unsplash.com/photo-1543429776-2782fc8e1acd?q=80&w=1964&auto=format&fit=crop",
  },
  {
    title: "Posar frente al Arco del Triunfo en París.",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?q=80&w=2073&auto=format&fit=crop",
  },
  {
    title: "Caminar junto al Coliseo Romano y revivir la historia.",
    image: "https://images.unsplash.com/photo-1552832230-c0197dd311b5?q=80&w=1996&auto=format&fit=crop",
  },
  {
    title: "Pisar la Plaza de San Pedro en el Vaticano.",
    image: "https://images.unsplash.com/photo-1531572751523-53b983713030?q=80&w=2070&auto=format&fit=crop",
  }
];
---
<section class="py-20 bg-white overflow-hidden">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 uppercase tracking-tight text-gray-800">
      NO SE TRATA SOLO DE CONOCER EUROPA, <span class="text-purple-deep block md:inline">SE TRATA DE:</span>
    </h2>

    <div class="space-y-24">
      {experiences.map((exp, index) => (
        <div class={`flex flex-col md:flex-row items-center gap-12 ${index % 2 !== 0 ? 'md:flex-row-reverse' : ''}`}>
          <div class="w-full md:w-1/2">
            <div class="relative group overflow-hidden rounded-2xl shadow-2xl">
              <img 
                src={exp.image} 
                alt={exp.title} 
                class="w-full h-[400px] object-cover transition-transform duration-700 group-hover:scale-110"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-purple-deep/40 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
          </div>
          <div class="w-full md:w-1/2 text-center md:text-left">
            <span class="text-5xl font-bold text-purple-deep/10 mb-4 block">0{index + 1}</span>
            <h3 class="text-2xl md:text-4xl font-bold text-gray-800 leading-tight">
              {exp.title}
            </h3>
            <div class="mt-6 w-20 h-1 bg-purple-deep mx-auto md:mx-0"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
