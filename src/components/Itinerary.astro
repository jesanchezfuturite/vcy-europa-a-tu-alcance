---
const stages = [
  {
    country: "España",
    description: "Vuela desde CDMX a Madrid. Recorrerás la Gran Vía, Burgos, la Sagrada Familia en Barcelona y la Basílica del Pilar en Zaragoza.",
    image: "https://images.unsplash.com/photo-1543783207-ec64e4d95325?q=80&w=2070&auto=format&fit=crop"
  },
  {
    country: "Francia",
    description: "Disfruta el espejo de agua nocturno en Burdeos, vive 3 días en París con la Torre Eiffel y recorre la Riviera Francesa.",
    image: "https://images.unsplash.com/photo-1502602898657-3e91760cbb34?q=80&w=2073&auto=format&fit=crop"
  },
  {
    country: "Suiza",
    description: "Camina por Lucerna junto a sus puentes medievales de madera y descubre el encanto alpino de Zúrich.",
    image: "https://images.unsplash.com/photo-1513622470522-26c3c8a854bc?q=80&w=2070&auto=format&fit=crop"
  },
  {
    country: "Italia & Vaticano",
    description: "Navega por Venecia, visita el Coliseo y el Vaticano en Roma, camina por Florencia y posa en la Torre Inclinada de Pisa.",
    image: "/images/venecia.webp"
  }
];
---
<section class="py-20 bg-purple-deep text-white overflow-hidden">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 uppercase tracking-tight">
      TU ITINERARIO EN UNA SOLA MIRADA
    </h2>

    <div class="relative max-w-5xl mx-auto">
      <!-- Carousel Container -->
      <div id="itinerary-carousel" class="flex transition-transform duration-500 ease-out">
        {stages.map((stage) => (
          <div class="w-full flex-shrink-0 px-4">
            <div class="bg-white/10 backdrop-blur-md rounded-3xl overflow-hidden border border-white/20 flex flex-col md:flex-row h-full">
              <div class="w-full md:w-1/2 h-64 md:h-auto">
                <img src={stage.image} alt={stage.country} class="w-full h-full object-cover" />
              </div>
              <div class="w-full md:w-1/2 p-8 md:p-12 flex flex-col justify-center">
                <span class="text-purple-300 font-bold tracking-widest uppercase mb-4 block">Destino</span>
                <h3 class="text-3xl md:text-5xl font-bold mb-6">{stage.country}</h3>
                <p class="text-lg md:text-xl leading-relaxed opacity-90">
                  {stage.description}
                </p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Navigation Arrows -->
      <button id="prev-btn" class="absolute left-0 top-1/2 -translate-y-1/2 -translate-x-2 md:-translate-x-12 bg-white text-purple-deep p-2 md:p-4 rounded-full shadow-2xl hover:scale-110 transition-all z-20">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M15 19l-7-7 7-7" />
        </svg>
      </button>
      <button id="next-btn" class="absolute right-0 top-1/2 -translate-y-1/2 translate-x-2 md:translate-x-12 bg-white text-purple-deep p-2 md:p-4 rounded-full shadow-2xl hover:scale-110 transition-all z-20">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 md:h-6 md:w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M9 5l7 7-7 7" />
        </svg>
      </button>

      <!-- Dots -->
      <div class="flex justify-center mt-10 gap-3">
        {stages.map((_, i) => (
          <button class="carousel-dot w-3 h-3 rounded-full bg-white/30 transition-all" data-index={i}></button>
        ))}
      </div>
    </div>
  </div>
</section>

<script>
  const carousel = document.getElementById('itinerary-carousel');
  const prevBtn = document.getElementById('prev-btn');
  const nextBtn = document.getElementById('next-btn');
  const dots = document.querySelectorAll('.carousel-dot');
  let currentIndex = 0;
  const totalItems = 4;

  function updateCarousel() {
    if (carousel) {
      carousel.style.transform = `translateX(-${currentIndex * 100}%)`;
    }
    dots.forEach((dot, i) => {
      dot.classList.toggle('bg-white', i === currentIndex);
      dot.classList.toggle('w-8', i === currentIndex);
      dot.classList.toggle('bg-white/30', i !== currentIndex);
    });
  }

  prevBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex > 0) ? currentIndex - 1 : totalItems - 1;
    updateCarousel();
  });

  nextBtn?.addEventListener('click', () => {
    currentIndex = (currentIndex < totalItems - 1) ? currentIndex + 1 : 0;
    updateCarousel();
  });

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      currentIndex = i;
      updateCarousel();
    });
  });

  // Initialize
  updateCarousel();
</script>
