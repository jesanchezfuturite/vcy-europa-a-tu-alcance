---
const supports = [
  {
    title: "Guía desde México",
    description: "Un coordinador de nuestro equipo viaja con el grupo todo el trayecto.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"/><line x1="4" x2="4" y1="22" y2="15"/></svg>`
  },
  {
    title: "Expertos locales",
    description: "Guías oficiales en español en cada ciudad para que no tengas barreras de idioma.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`
  },
  {
    title: "Autocar de gran lujo",
    description: "Traslados privados entre países; olvídate de trenes o cargar maletas en el metro.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8 6v6"/><path d="M15 6v6"/><path d="M2 12h19.6"/><path d="M18 18h3s.5-1.7.8-2.8c.1-.4.2-.8.2-1.2 0-.4-.1-.8-.2-1.2l-1.4-5C20.1 6.8 19.1 6 18 6H4a2 2 0 0 0-2 2v10h3"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>`
  },
  {
    title: "Asistencia 24/7",
    description: "Soporte personalizado antes y durante cada día de tu viaje por Europa.",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-10 h-10 text-purple-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`
  }
];
---
<section class="py-20 bg-gray-50">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 text-gray-800 uppercase tracking-tight">
      EL RESPALDO QUE NECESITAS AL VIAJAR LEJOS
    </h2>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {supports.map(support => (
        <div class="bg-white p-8 rounded-2xl shadow-sm hover:shadow-xl transition-shadow duration-300 border border-gray-100">
          <div class="mb-6" set:html={support.icon}></div>
          <h3 class="text-xl font-bold mb-4 text-purple-deep">{support.title}</h3>
          <p class="text-gray-600 leading-relaxed">
            {support.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
