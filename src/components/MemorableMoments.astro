---
const moments = [
  {
    title: "Tu primera noche en París",
    description: "Ver encenderse la Torre Eiffel iluminando toda la ciudad frente a ti.",
    icon: "🗼"
  },
  {
    title: "Navegar hacia Venecia",
    description: "Cruzar la laguna en un auténtico Vaporetto directo a la Plaza de San Marcos.",
    icon: "🛶"
  },
  {
    title: "La Roma Imperial a pie",
    description: "Estar frente al Coliseo Romano y revivir la historia que viste en películas.",
    icon: "🏛️"
  }
];
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 text-gray-800 uppercase tracking-tight">
      LOS MOMENTOS QUE RECORDARÁS PARA SIEMPRE
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      {moments.map(moment => (
        <div class="group bg-gray-50 p-10 rounded-3xl transition-all duration-300 hover:bg-purple-deep hover:text-white hover:-translate-y-2 shadow-sm">
          <div class="text-5xl mb-6 group-hover:scale-110 transition-transform duration-300">
            {moment.icon}
          </div>
          <h3 class="text-2xl font-bold mb-4">{moment.title}</h3>
          <p class="text-lg opacity-80 leading-relaxed">
            {moment.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
