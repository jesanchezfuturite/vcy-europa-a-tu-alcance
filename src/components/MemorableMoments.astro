---
const moments = [
  {
    title: "Tu primera noche en París",
    description: "Ver encenderse la Torre Eiffel iluminando toda la ciudad frente a ti.",
    image: "/images/paris_night.jpg"
  },
  {
    title: "Navegar hacia Venecia",
    description: "Cruzar la laguna en un auténtico Vaporetto directo a la Plaza de San Marcos.",
    image: "/images/venice_vaporetto.jpg"
  },
  {
    title: "La Roma Imperial a pie",
    description: "Estar frente al Coliseo Romano y revivir la historia que viste en películas.",
    image: "/images/rome_colosseum.jpg"
  }
];
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <h2 class="text-3xl md:text-4xl font-bold text-center mb-16 text-gray-800 uppercase tracking-tight">
      LOS MOMENTOS QUE RECORDARÁS PARA SIEMPRE
    </h2>

    <div class="grid md:grid-cols-3 gap-8">
      {moments.map(moment => (
        <div class="relative group p-10 rounded-3xl transition-all duration-300 hover:-translate-y-2 shadow-sm overflow-hidden flex flex-col justify-end min-h-[350px]">
          <img src={moment.image} alt={moment.title} class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 z-0" />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/10 group-hover:from-purple-deep group-hover:via-purple-deep/80 group-hover:to-purple-deep/40 transition-colors duration-300 z-10"></div>
          
          <div class="relative z-20 text-white mt-auto">
            <h3 class="text-2xl font-bold mb-4">{moment.title}</h3>
            <p class="text-lg opacity-90 leading-relaxed">
              {moment.description}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
