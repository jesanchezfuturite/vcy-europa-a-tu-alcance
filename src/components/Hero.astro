---
---
<section class="relative min-h-[80vh] flex items-center justify-center bg-gray-900 overflow-hidden">
  <!-- Overlay/Background Simulation -->
  <div class="absolute inset-0 z-0 opacity-40">
    <div class="absolute inset-0 bg-gradient-to-b from-black/60 to-purple-deep/40"></div>
    <img 
      src="/images/eiffel.webp" 
      alt="Europa" 
      class="w-full h-full object-cover"
    />
  </div>

  <div class="container mx-auto px-4 z-10 text-center text-white">
    <span class="inline-block px-4 py-1 mb-6 border border-white/30 rounded-full text-sm font-semibold tracking-widest uppercase animate-fade-in">
      EUROPA A TU ALCANCE 2027
    </span>
    
    <h1 class="text-3xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
      CUMPLE TU SUEÑO DE CONOCER <br class="hidden md:block" />
      <span class="text-purple-300">EUROPA ESTE 2027</span>
    </h1>
    
    <p class="text-lg md:text-2xl mb-2 font-medium">
      17 días / 15 noches · Salida única: 08 de Febrero de 2027
    </p>
    
    <div class="mb-8">
      <span class="text-3xl md:text-4xl font-bold text-white block mb-2">
        $47,200 MXN
      </span>
      <span class="text-lg opacity-90">(Por persona en habitación doble)</span>
    </div>

    <div class="bg-white/10 backdrop-blur-sm border border-white/20 inline-block px-6 py-4 rounded-xl mb-10">
      <p class="text-xl font-semibold">
        Aparta hoy con solo <span class="text-purple-300">$5,500 MXN</span>
      </p>
    </div>

    <div>
      <a 
        href="#formulario-contacto" 
        class="inline-block bg-purple-deep hover:bg-purple-800 text-white text-xl font-bold px-10 py-5 rounded-full transition-all hover:scale-105 shadow-xl"
      >
        Quiero reservar mi lugar a Europa
      </a>
      <p class="mt-4 text-sm opacity-80 italic">
        Cupo limitado · Atención antes y durante el viaje
      </p>
    </div>
  </div>
</section>

<style>
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-in {
    animation: fadeIn 1s ease-out forwards;
  }
</style>
